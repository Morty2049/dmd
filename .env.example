# dmd environment variables.
# Copy to .env and fill in. .env is git-ignored.

# ── Phase 0 (local) ─────────────────────────────────────────────
# Path to the append-only JSONL log. Created on first append.
DMD_LOG_PATH=data/swarm.jsonl

# Path to the Obsidian vault that the exporter materializes.
DMD_VAULT_PATH=vault

# ── Phase 2 (production) — unused in Phase 0 ────────────────────
# NATS JetStream cluster for the swarm transport.
# NATS_URL=nats://localhost:4222
# NATS_STREAM=swarm_v1
# NATS_SUBJECT_PREFIX=swarm.v1

# ClickHouse — append-only log storage.
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_DB=dmd
# CLICKHOUSE_TABLE=swarm_log

# Qdrant — semantic index over the log.
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=dmd_messages

# LLM providers for agent runners.
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
